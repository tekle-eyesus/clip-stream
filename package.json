{
  "name": "clip-stream",
  "displayName": "Clip Stream",
  "description": "A VS Code extension for clipboard history in a sidebar view.",
  "version": "0.0.1",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:clipStream.sidebar",
    "onCommand:clip-stream.hello"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "clip-stream.hello",
        "title": "Clip Stream: Hello"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clipStream",
          "title": "Clip Stream"
        }
      ]
    },
    "views": {
      "clipStream": [
        {
          "id": "clipStream.sidebar",
          "name": "History"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.0"
  }
}
